# ===========================================
# 程序配置（.env）— 账号、服务器、API 等
# 游戏内设置请编辑 config/game/ 目录
# ===========================================

# Minecraft 服务器
MC_HOST=mc.zenoxs.cn
MC_PORT=25565
MC_USERNAME=your_microsoft_email@example.com
# 仅 mojang/offline 认证需要密码，微软账号请留空或删除此行
MC_PASSWORD=
MC_AUTH=microsoft
MC_PROFILES_FOLDER=./mc-tokens
MC_VERSION=false
MC_CHECK_TIMEOUT=300000

# AstrBot (QQ群) — 设为 true 启用
ASTRBOT_ENABLED=false
API_PORT=15100
API_KEY=your_api_key_here

# 消息队列
QUEUE_MAX_SIZE=100
QUEUE_DELAY_MS=1000

# 管理员游戏名（逗号分隔）
MC_ADMIN_LIST=
